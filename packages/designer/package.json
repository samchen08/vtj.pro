{
  "name": "@vtj/designer",
  "private": false,
  "version": "0.18.7",
  "type": "module",
  "keywords": [
    "低代码引擎",
    "LowCode Engine",
    "Vue3低代码",
    "低代码渲染器",
    "低代码设计器",
    "代码生成器",
    "代码可视化"
  ],
  "description": "VTJ.PRO 是一个开源的、AI 驱动的 Vue3 企业级应用开发平台，通过 AI 智能体与可视化编排实现高效开发，并支持导出标准 Vue 代码以避免平台锁定。",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/newgateway/vtj.git"
  },
  "homepage": "https://gitee.com/newgateway/vtj",
  "author": "chenhuachun",
  "license": "MIT",
  "scripts": {
    "build": "vue-tsc && vite build",
    "test": "vitest run",
    "vitest": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vtj/core": "workspace:~",
    "@vtj/icons": "workspace:~",
    "@vtj/renderer": "workspace:~",
    "@vtj/ui": "workspace:~",
    "@vtj/uni": "workspace:~",
    "@vtj/utils": "workspace:~",
    "@vue/devtools-core": "~8.0.2",
    "@vue/devtools-kit": "~8.0.2",
    "highlight.js": "~11.11.1",
    "hotkeys-js": "~3.13.15",
    "html2canvas": "~1.4.1",
    "marked": "~17.0.1",
    "mockjs": "~1.1.0",
    "monaco-editor": "~0.55.0"
  },
  "devDependencies": {
    "@types/mockjs": "~1.0.10",
    "@vtj/cli": "workspace:~",
    "vue": "~3.5.37",
    "vue-router": "~4.6.0"
  },
  "files": [
    "dist",
    "types"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "types/index.d.ts",
  "exports": {
    "./dist/style.css": "./dist/style.css",
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
